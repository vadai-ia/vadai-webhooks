# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxx

# App
NEXT_PUBLIC_APP_URL=https://webhooks.vadai.com.mx

# Auth: ya no hay filtro por dominio. El acceso se controla con la tabla
# vw_allowed_users (ver supabase/schema.sql). Para autorizar a alguien:
#   1. Crearlo en Supabase Auth (Authentication → Users → Add user)
#   2. INSERT INTO vw_allowed_users (email) VALUES ('persona@dominio.com')

# ─── Handler: genco-soft-odoo ───────────────────────────────────────────
# Odoo 19 multi-empresa de GENCO. ODOO_URL acepta cualquier path después
# del host (el cliente lo normaliza a {origin}/jsonrpc).
ODOO_URL=https://your-tenant.odoo.com
ODOO_DB=your_db
ODOO_USER=api_user@your-domain.com
ODOO_API_KEY=xxxxxxxx

# ─── Handler: vadai-cumpleanos ──────────────────────────────────────────
# Odoo tenant interno de VADAI. Lee hr.employee.birthday para notificar
# cumpleaños del equipo. Cron diario externo dispara el webhook.
ODOO_VADAI_URL=https://vadai.odoo.com
ODOO_VADAI_DB=vadai
ODOO_VADAI_USER=api_user@vadai.com.mx
ODOO_VADAI_API_KEY=xxxxxxxx

# ─── Handler: fireflies-alex-transcript ─────────────────────────────────
# Fireflies → un agente OpenAI clasifica los action items dentro de los
# proyectos "LEVANTIA - <cliente>" del Odoo de VADAI (reusa ODOO_VADAI_*).
# FIREFLIES_API_KEY: Fireflies → Settings → Developer (Bearer de la GraphQL API).
FIREFLIES_API_KEY=xxxxxxxx
# Filtro `name ilike` para los proyectos candidatos que ve la IA.
FIREFLIES_LEVANTIA_MATCH=LEVANTIA
# Proyecto de triage para los items que la IA no clasifica con confianza
# (búsqueda por nombre exacto). Si no existe, la tarea queda privada para Alex.
FIREFLIES_INBOX_PROJECT=Inbox
# Etapa kanban destino. Si el proyecto ya tiene etapas, se usa la primera
# (por sequence); solo si el proyecto NO tiene etapas se crea una con este nombre.
FIREFLIES_TASK_STAGE=Por hacer
# Usuario fallback (res.users por email) para items sin responsable
# identificable. Vacío = usa el usuario de la API (ODOO_VADAI_USER).
FIREFLIES_FALLBACK_USER_EMAIL=

# ─── OpenAI (agente clasificador de fireflies-alex-transcript) ──────────
# Clasifica proyecto, redacta títulos y propone fechas de entrega.
OPENAI_API_KEY=sk-xxxxxxxx
# Modelo con soporte de Structured Outputs (gpt-4o, gpt-4.1, gpt-4o-mini…).
OPENAI_MODEL=gpt-4o
